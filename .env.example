# Lily — example environment file.
# Copy to `.env` and fill in the blanks: `cp .env.example .env`
# Every value here is a PLACEHOLDER — no real secret is committed to this repo.
# The local Postgres/Redis defaults match docker-compose.yml, so the core block
# works out of the box after `docker compose up -d`.

# ─────────────────────────────────────────────────────────────────────────────
# Core (required for local development)
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
DATABASE_URL=postgresql://lily:lily123@localhost:5432/lily
DATABASE_URL_TEST=postgresql://lily:lily123@localhost:5433/lily_test
KNOWLEDGE_DATABASE_URL=postgresql://lily:lily123@localhost:5434/lily_knowledge
REDIS_URL=redis://localhost:6379
API_BASE_URL=http://localhost:3000

# Auth / tokens — generate long random strings, e.g. `openssl rand -hex 32`
JWT_SECRET=replace-with-a-long-random-secret
JWT_ISSUER=lily
JWT_ACCESS_TOKEN_EXPIRY=15 minutes
# Shared secret for the internal service-to-service API (X-Service-Secret header)
SERVICE_TOKEN_SECRET=replace-with-a-long-random-secret

# ─────────────────────────────────────────────────────────────────────────────
# AI & RAG
# ─────────────────────────────────────────────────────────────────────────────
# Used by @ai-sdk/openai for plant chat + knowledge-base enrichment.
OPENAI_API_KEY=sk-your-openai-api-key
# Weather signal for the watering model.
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# ─────────────────────────────────────────────────────────────────────────────
# Email (Resend)
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
[email protected]
EMAIL_FROM_NAME=Lily

# ─────────────────────────────────────────────────────────────────────────────
# File storage (Google Cloud Storage)
# ─────────────────────────────────────────────────────────────────────────────
# Full service-account JSON as a single-line string (kept out of the repo).
GCS_CREDENTIALS_JSON=
GCS_PLANT_BUCKET=lily-plant-photos
GCS_AI_BUCKET=lily-ai-assets

# ─────────────────────────────────────────────────────────────────────────────
# Auth: Google OAuth (public client IDs — not secrets)
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_OAUTH_WEB_CLIENT_ID=
GOOGLE_OAUTH_IOS_CLIENT_ID=
GOOGLE_OAUTH_ANDROID_CLIENT_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Push notifications (Apple Push Notification service)
# ─────────────────────────────────────────────────────────────────────────────
PUSH_PROVIDER=apns
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.lilyapp.app
APPLE_BUNDLE_ID=com.lilyapp.app
# The .p8 key contents (multiline → escape newlines as \n, or supply as one line).
APNS_PRIVATE_KEY=
# `sandbox` for dev/TestFlight, `production` for App Store builds.
APNS_ENVIRONMENT=sandbox

# ─────────────────────────────────────────────────────────────────────────────
# Subscriptions (RevenueCat)
# ─────────────────────────────────────────────────────────────────────────────
REVENUECAT_API_KEY=
REVENUECAT_WEBHOOK_AUTH_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# App Store / Play reviewer instant-login (optional; submission only)
# ─────────────────────────────────────────────────────────────────────────────
# Comma-separated allowlist of emails that may use magic-link instant login.
# Keep EMPTY unless an app-store review is in progress, and clear it afterwards.
REVIEWER_EMAILS=
# Consumed by `bun run seed:apple-reviewer` / `seed:android-reviewer`.
[email protected]
[email protected]
# Must stay false in production (fails closed when unset).
DISABLE_MAGIC_LINK_VERIFICATION=false

# ─────────────────────────────────────────────────────────────────────────────
# Alerting (Discord)
# ─────────────────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=
ALERT_ENVIRONMENT_NAME=local

# ─────────────────────────────────────────────────────────────────────────────
# Automated content generation (GitHub-backed blog/tips)
# ─────────────────────────────────────────────────────────────────────────────
BLOG_GENERATION_ENABLED=false
TIPS_GENERATION_ENABLED=false
GITHUB_TOKEN=
GITHUB_REPO=antoine2vey/lily
GITHUB_BRANCH=main

# ─────────────────────────────────────────────────────────────────────────────
# Observability (OpenTelemetry — optional)
# ─────────────────────────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=lily-api

# ─────────────────────────────────────────────────────────────────────────────
# MCP server (packages/mcp)
# ─────────────────────────────────────────────────────────────────────────────
MCP_PORT=3001
MCP_SERVER_URL=http://localhost:3001
# Comma-separated browser origin allowlist. Empty = deny all cross-origin (CORS
# fails closed); set explicit origins to enable browser-based MCP clients.
MCP_ALLOWED_ORIGINS=

# Feature flag: bypass subscription usage limits locally (never enable in prod).
DISABLE_LIMITS=false

# ─────────────────────────────────────────────────────────────────────────────
# Client apps (build-time public values — NOT secrets)
#   packages/app  → EXPO_PUBLIC_* (set via EAS environments in CI)
#   packages/admin → VITE_API_URL
#   packages/web   → NEXT_PUBLIC_GA_ID
# ─────────────────────────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_PROJECT_ID=
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=
EXPO_PUBLIC_SENTRY_DSN=
VITE_API_URL=http://localhost:3000
NEXT_PUBLIC_GA_ID=
