+// Patch: Map to preserve original string JSON-RPC IDs through the
+// BigInt-based internal pipeline. @effect/rpc uses BigInt(id) internally
+// which crashes on non-numeric string IDs (e.g. "init_1") that clients
+// like Claude.ai send per the JSON-RPC 2.0 spec.
+var _stringIdCounter = 900000;
+var _originalIds = new Map();
+function _toNumericId(rawId) {
+  if (rawId == null) return "";
+  if (typeof rawId === "number") return String(rawId);
+  var str = String(rawId);
+  if (/^\d+$/.test(str)) return str;
+  var numId = String(_stringIdCounter++);
+  _originalIds.set(numId, rawId);
+  return numId;
+}
+function _restoreId(numericStr) {
+  if (numericStr == null) return undefined;
+  var str = String(numericStr);
+  var orig = _originalIds.get(str);
+  if (orig !== undefined) {
+    _originalIds.delete(str);
+    return orig;
+  }
+  return Number(str);
+}
