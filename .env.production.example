# Production Environment Variables

# Database
DATABASE_URL=postgresql://lily:your-secure-password@postgres:5432/lily
POSTGRES_USER=lily
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=lily

# Redis
REDIS_URL=redis://redis:6379

# App
NODE_ENV=production

