echo "🔍 Running pre-commit lint check..."

# Capture originally-staged files before lint:fix can touch them.
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

bun run lint:fix
if [ $? -ne 0 ]; then
    echo "❌ Linting failed! Please fix the issues before committing."
    exit 1
fi

# Re-stage only files that were already staged — don't sweep in unrelated
# working-tree changes that the user intentionally left out of this commit.
if [ -n "$STAGED_FILES" ]; then
    echo "$STAGED_FILES" | xargs -r git add
fi

echo "✅ Pre-commit checks passed!"
