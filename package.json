{
  "name": "lily-monorepo",
  "version": "1.0.0",
  "devDependencies": {
    "@biomejs/biome": "2.1.3",
    "husky": "^9.1.7",
    "turbo": "^2.3.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.0.0",
  "private": true,
  "resolutions": {
    "@effect/platform": "0.90.0",
    "effect": "3.17.5"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "test:integration": "bun --env-file=.env.test.local run --filter=@lily/api test:integration",
    "db:setup-test": "bun --env-file=.env.test.local run --filter=@lily/db db:setup-test",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "clean": "turbo clean",
    "prepare": "husky"
  },
  "workspaces": [
    "packages/*"
  ]
}
