{
  "name": "lily-monorepo",
  "version": "1.0.0",
  "devDependencies": {
    "@babel/runtime": "^7.28.6",
    "@biomejs/biome": "2.1.3",
    "husky": "^9.1.7",
    "turbo": "^2.8.9",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.8",
  "private": true,
  "resolutions": {
    "@effect/platform": "0.90.0",
    "effect": "3.17.5",
    "react": "19.1.0",
    "@opentelemetry/resources": "1.30.1",
    "@opentelemetry/sdk-trace-base": "1.30.1",
    "@opentelemetry/sdk-trace-node": "1.30.1",
    "@opentelemetry/core": "1.30.1",
    "vite": "^6.0.0"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "test:integration": "bun --env-file=.env.test.local run --filter=@lily/api test:integration",
    "db:setup-test": "bun --env-file=.env.test.local run --filter=@lily/db db:setup-test",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "tsc": "turbo tsc",
    "clean": "turbo clean",
    "prepare": "husky"
  },
  "workspaces": [
    "packages/*"
  ]
}
