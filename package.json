{
  "name": "lily-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter=* build",
    "dev": "bun run --filter=* dev",
    "test": "bun run --filter=* test",
    "lint": "bun run --filter=* lint",
    "lint:fix": "bun run --filter=* lint:fix",
    "clean": "bun run --filter=* clean"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.4",
    "prisma": "^6.10.1",
    "typescript": "^5.3.3"
  },
  "packageManager": "bun@1.0.0"
}
