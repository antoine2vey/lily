{
  "name": "@lily/db",
  "version": "1.0.0",
  "description": "Database service and Drizzle configuration",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "tsc": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "echo 'No tests yet'",
    "lint": "bunx --bun biome check .",
    "lint:fix": "bunx --bun biome check --write .",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:prod": "bun run scripts/migrate.ts",
    "db:seed:prod": "bun run scripts/seed-tiers-prod.ts",
    "db:studio": "drizzle-kit studio",
    "seed:admin": "bun run scripts/seed-admin.ts",
    "seed:apple-reviewer": "bun run scripts/seed-apple-reviewer.ts",
    "seed:tiers": "bun run scripts/seed-subscription-tiers.ts",
    "seed:demo": "bun run scripts/seed-demo-data.ts",
    "db:push-test": "DATABASE_URL=$DATABASE_URL_TEST drizzle-kit push",
    "db:setup-test": "bun run db:push-test && bun run scripts/setup-test-db.ts"
  },
  "dependencies": {
    "@effect/experimental": "^0.58.0",
    "@effect/platform": "^0.94.5",
    "@effect/sql": "^0.49.0",
    "@effect/sql-drizzle": "^0.48.0",
    "@effect/sql-pg": "^0.50.1",
    "@lily/shared": "workspace:*",
    "better-auth": "^1.3.4",
    "drizzle-orm": "^0.45.1",
    "effect": "^3.19.19",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5.9.2"
  }
}
