{
  "name": "@lily/mcp",
  "version": "1.0.0",
  "description": "MCP server for Lily plant care",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "bun --watch src/index.ts",
    "start": "bun run src/index.ts",
    "tsc": "NODE_OPTIONS='--max-old-space-size=8192' tsc --noEmit",
    "test": "vitest run",
    "lint": "bunx --bun biome check .",
    "lint:fix": "bunx --bun biome check --write .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@effect/platform": "^0.90.0",
    "@effect/sql": "^0.49.0",
    "@effect/sql-drizzle": "^0.48.0",
    "@lily/api": "workspace:*",
    "@lily/db": "workspace:*",
    "@lily/knowledge-db": "workspace:*",
    "@lily/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "drizzle-orm": "^0.45.1",
    "effect": "^3.17.5",
    "express": "^5.1.0",
    "mcp-oauth-server": "^0.0.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/bun": "^1.3.8",
    "typescript": "^5.9.2",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
