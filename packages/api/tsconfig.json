{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false,
    "composite": true,
    "target": "ES2022",
    "baseUrl": ".",
    "paths": {
      "@lily/api": ["./src"],
      "@lily/api/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "test"],
  "references": [{ "path": "../shared" }, { "path": "../db" }]
}
