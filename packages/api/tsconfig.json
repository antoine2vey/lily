{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": false,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@lily/*": ["../../packages/*/src"],
      "@lily/packages/*": ["../../packages/*/src"],
      "@lily/api": ["./src"],
      "@lily/api/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "test"],
  "references": []
}
