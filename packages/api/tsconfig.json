{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "noEmit": false,
    "composite": true,
    "target": "ES2022",
    "baseUrl": ".",
    "paths": {
      "@lily/api": ["./src"],
      "@lily/api/*": ["./src/*"],
      "@lily/shared": ["../shared/dist"],
      "@lily/shared/*": ["../shared/dist/*"],
      "@lily/db": ["../db/dist"],
      "@lily/db/*": ["../db/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules", "test"]
}
