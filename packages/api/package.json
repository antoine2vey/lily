{
  "name": "@lily/api",
  "version": "1.0.0",
  "description": "Node.js API with Effect RPC",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsc --build tsconfig.build.json",
    "dev": "bun --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "vitest run",
    "test:integration": "vitest run src/__tests__/integration --no-file-parallelism",
    "lint": "bunx --bun biome check .",
    "lint:fix": "bunx --bun biome check --write .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@effect/opentelemetry": "^0.60.0",
    "@effect/platform": "^0.90.0",
    "@effect/platform-bun": "^0.77.0",
    "@lily/db": "workspace:*",
    "@lily/shared": "workspace:*",
    "@opentelemetry/exporter-trace-otlp-http": "^0.211.0",
    "@opentelemetry/resources": "^2.5.0",
    "@opentelemetry/sdk-node": "^0.211.0",
    "@opentelemetry/sdk-trace-node": "^2.5.0",
    "@opentelemetry/sdk-trace-web": "^2.5.0",
    "@opentelemetry/semantic-conventions": "^1.39.0",
    "effect": "^3.17.5",
    "expo-server-sdk": "^4.0.0",
    "ioredis": "^5.9.1",
    "jose": "^6.1.3",
    "qrcode-terminal": "^0.12.0",
    "resend": "^6.7.0",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@types/pg": "^8.16.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "pg": "^8.16.3",
    "supertest": "^7.1.4",
    "tsx": "^4.20.3",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^3.2.4"
  }
}
