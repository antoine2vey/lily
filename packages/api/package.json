{
  "name": "@lily/api",
  "version": "1.0.0",
  "description": "Node.js API with Effect RPC",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "lint": "bunx --bun biome check .",
    "lint:fix": "bunx --bun biome check --write .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.0",
    "@effect/platform": "^0.90.0",
    "@effect/platform-bun": "^0.77.0",
    "@lily/db": "workspace:*",
    "@lily/shared": "workspace:*",
    "ai": "^5.0.0",
    "effect": "^3.17.5",
    "resend": "^6.7.0",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "supertest": "^7.1.4",
    "tsx": "^4.20.3",
    "vitest": "^3.2.4"
  }
}
