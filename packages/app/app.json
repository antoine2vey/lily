{
  "expo": {
    "name": "Lily",
    "slug": "lily",
    "version": "1.0.0",
    "owner": "lilyapp",
    "orientation": "portrait",
    "icon": "./assets/icon-light.png",
    "userInterfaceStyle": "automatic",
    "scheme": "lily",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon-light.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAF8"
    },
    "ios": {
      "icon": "./assets/lily.icon",
      "splash": {
        "dark": {
          "image": "./assets/icon-dark.png",
          "resizeMode": "contain",
          "backgroundColor": "#1A1A1A"
        }
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.lilyapp.app",
      "appleTeamId": "K7Y594Y8M3",
      "usesAppleSignIn": true,
      "usesIAP": true,
      "entitlements": {
        "com.apple.developer.usernotifications.time-sensitive": true
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Lily uses your location to provide local weather data and adjust your plant care schedule accordingly."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f7f7f6"
      },
      "splash": {
        "dark": {
          "image": "./assets/icon-dark.png",
          "resizeMode": "contain",
          "backgroundColor": "#1A1A1A"
        }
      },
      "package": "com.lilyapp.app",
      "edgeToEdgeEnabled": true,
      "permissions": ["ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "./plugins/withLiveActivity",
      "@lily/plant-scanner",
      "expo-dev-client",
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.761780678731-iplm62u17pl0hanf9o3j9i9vsi7nt9pm"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F8FAF8",
          "image": "./assets/icon-light.png",
          "imageWidth": 200,
          "dark": {
            "backgroundColor": "#1A1A1A",
            "image": "./assets/icon-dark.png"
          }
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Lily needs camera access to identify your plants and measure lighting conditions.",
          "enableFrameProcessors": true
        }
      ],
      [
        "react-native-fast-tflite",
        {
          "enableCoreMLDelegate": true,
          "enableAndroidGpuLibraries": true
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Lily uses your location to provide local weather data and adjust your plant care schedule accordingly."
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "antoine2vey"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-font",
        {
          "android": {
            "fonts": [
              {
                "fontFamily": "material",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/MaterialIcons.ttf",
                    "weight": 400
                  }
                ]
              }
            ]
          },
          "ios": {
            "fonts": ["./assets/fonts/MaterialIcons.ttf"]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "1e455743-41d3-49dc-928c-d176d40875e9",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "LilyWidgetsExtension",
                  "bundleIdentifier": "com.lilyapp.app.LilyWidgets"
                }
              ]
            }
          }
        }
      },
      "router": {}
    },
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/1e455743-41d3-49dc-928c-d176d40875e9",
      "checkOnLaunch": "ALWAYS",
      "fallbackToCacheTimeout": 0
    }
  }
}
