{
  "name": "@lily/shared",
  "version": "1.0.0",
  "description": "Shared utilities and types",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
