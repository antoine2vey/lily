  },
  "devDependencies": {
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.0",
    "@google-cloud/storage": "^7.16.0",
    "ai": "^5.0.0",
    "effect": "^3.17.5",
    "@effect/platform": "^0.90.0",
    "@lily/db": "workspace:*",
    "zod": "^4.0.14"
