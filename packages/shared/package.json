    },
    "./selectors/plant": {
      "types": "./src/domains/plant/selectors.ts",
      "default": "./src/domains/plant/selectors.ts"
    },
    "./services/*": {
      "types": "./src/services/*.ts",
      "default": "./src/services/*.ts"
    }
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "test": "echo 'No tests yet'",
    "lint": "bunx --bun biome check .",
    "lint:fix": "bunx --bun biome check --write .",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.0",
    "@google-cloud/storage": "^7.16.0",
    "ai": "^5.0.0",
    "effect": "^3.17.5",
    "@effect/platform": "^0.90.0",
    "zod": "^4.0.14"
  }
