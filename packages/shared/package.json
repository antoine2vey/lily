{
  "name": "@lily/shared",
  "version": "1.0.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "description": "Shared utilities and types",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./src/server.ts"
    },
    "./achievement": {
      "types": "./src/domains/achievement/schema.ts",
      "default": "./src/domains/achievement/schema.ts"
    },
    "./admin": {
      "types": "./src/domains/admin/schema.ts",
      "default": "./src/domains/admin/schema.ts"
    },
    "./admin/analytics": {
      "types": "./src/domains/admin/analytics/index.ts",
      "default": "./src/domains/admin/analytics/index.ts"
    },
    "./ai-chat": {
      "types": "./src/domains/ai-chat/index.ts",
      "default": "./src/domains/ai-chat/index.ts"
    },
    "./auth": {
      "types": "./src/domains/auth/schema.ts",
      "default": "./src/domains/auth/schema.ts"
    },
    "./care-log": {
      "types": "./src/domains/care-log/schema.ts",
      "default": "./src/domains/care-log/schema.ts"
    },
    "./common": {
      "types": "./src/domains/common/schema.ts",
      "default": "./src/domains/common/schema.ts"
    },
    "./diagnosis": {
      "types": "./src/domains/diagnosis/schema.ts",
      "default": "./src/domains/diagnosis/schema.ts"
    },
    "./device-token": {
      "types": "./src/domains/device-token/schema.ts",
      "default": "./src/domains/device-token/schema.ts"
    },
    "./notification": {
      "types": "./src/domains/notification/schema.ts",
      "default": "./src/domains/notification/schema.ts"
    },
    "./plant": {
      "types": "./src/domains/plant/schema.ts",
      "default": "./src/domains/plant/schema.ts"
    },
    "./user": {
      "types": "./src/domains/user/schema.ts",
      "default": "./src/domains/user/schema.ts"
    },
    "./username": {
      "types": "./src/domains/username/schema.ts",
      "default": "./src/domains/username/schema.ts"
    },
    "./knowledge": {
      "types": "./src/domains/knowledge/index.ts",
      "default": "./src/domains/knowledge/index.ts"
    },
    "./errors/knowledge": {
      "types": "./src/domains/knowledge/errors.ts",
      "default": "./src/domains/knowledge/errors.ts"
    },
    "./errors/care-log": {
      "types": "./src/domains/care-log/errors.ts",
      "default": "./src/domains/care-log/errors.ts"
    },
    "./errors/diagnosis": {
      "types": "./src/domains/diagnosis/errors.ts",
      "default": "./src/domains/diagnosis/errors.ts"
    },
    "./errors/database": {
      "types": "./src/domains/common/errors.ts",
      "default": "./src/domains/common/errors.ts"
    },
    "./errors/plant": {
      "types": "./src/domains/plant/errors.ts",
      "default": "./src/domains/plant/errors.ts"
    },
    "./errors/user": {
      "types": "./src/domains/user/errors.ts",
      "default": "./src/domains/user/errors.ts"
    },
    "./errors/admin": {
      "types": "./src/domains/admin/errors.ts",
      "default": "./src/domains/admin/errors.ts"
    },
    "./errors/gift-code": {
      "types": "./src/domains/gift-code/errors.ts",
      "default": "./src/domains/gift-code/errors.ts"
    },
    "./selectors/plant": {
      "types": "./src/domains/plant/selectors.ts",
      "default": "./src/domains/plant/selectors.ts"
    },
    "./services/*": {
      "types": "./src/services/*.ts",
      "default": "./src/services/*.ts"
    }
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "tsc": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "bunx --bun biome check .",
    "lint:fix": "bunx --bun biome check --write .",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsc-alias": "^1.8.16",
    "typescript": "^6.0.2",
    "vitest": "^3.1.3"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.0",
    "@google-cloud/storage": "^7.16.0",
    "ai": "^6.0.0",
    "effect": "^3.19.19",
    "@effect/platform": "^0.94.5",
    "zod": "^4.0.14"
  }
}
